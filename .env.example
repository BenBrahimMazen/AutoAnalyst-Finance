# =============================================================================
# AutoAnalyst Finance — environment template
# Copy this file to ".env" and fill in your keys. The real ".env" is gitignored.
# =============================================================================

# ---- Web search (required for the news/sentiment agent) ---------------------
# Free key: https://app.tavily.com/  (sign up -> API Keys)
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Macro data (optional; hardcoded fallback used if missing) --------------
# Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# LLM PROVIDER — pick ONE block below. All are OpenAI-compatible, so the same
# LangChain ChatOpenAI client works for any of them.
# =============================================================================

# ---- Option A: OpenAI (paid) ------------------------------------------------
# Get a key + add billing at https://platform.openai.com/
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Option B: Google Gemini (RECOMMENDED — free, generous quota) -----------
# Free key: https://aistudio.google.com/apikey
# Then set these three (LLM_* take precedence over OPENAI_*):
# LLM_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash

# ---- Option C: Groq (free, very fast — Llama models) ------------------------
# Free key: https://console.groq.com/keys
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ---- Option D: OpenRouter (free tier models available) ----------------------
# Free key: https://openrouter.ai/keys
# LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Option E: Ollama (100% free, LOCAL — no internet/quota) -----------------
# Install: https://ollama.com  then `ollama pull llama3.1`
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
